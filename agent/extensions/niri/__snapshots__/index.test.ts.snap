// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`formatFocusedOutput > given minimal output, then matches snapshot 1`] = `
"name │ VGA-1
 vrr │ ○ vrr"
`;

exports[`formatFocusedOutput > given output with full info, then matches snapshot 1`] = `
" name │ DP-1
 make │ LG
model │ 27GL850
 mode │ 2560x1440@144Hz
scale │ 1x
  vrr │ ● vrr"
`;

exports[`formatFocusedWindow > given floating window without title, then matches snapshot 1`] = `
"      id │ 99
     app │ mpv
   title │ untitled
floating │ yes"
`;

exports[`formatFocusedWindow > given focused window, then matches snapshot 1`] = `
"       id │ 1
      app │ code
    title │ My Editor
workspace │ 1"
`;

exports[`formatOutputs > then matches snapshot 1`] = `
"2 output(s)

name     │ resolution      │ scale │ vrr
─────────┼─────────────────┼───────┼──────
DP-1     │ 2560x1440@144Hz │    1x │ ● vrr
HDMI-1   │ 1920x1080       │    1x │ ○ vrr"
`;

exports[`formatPickedWindow > given window, then matches snapshot 1`] = `
"       id │ 2
      app │ firefox
    title │ Firefox — GitHub
workspace │ 1
 floating │ yes"
`;

exports[`formatWindows > given empty list, then matches snapshot 1`] = `
"0 window(s)

"
`;

exports[`formatWindows > then matches snapshot 1`] = `
"3 window(s)

  id │ app          │ title            │ flags
─────┼──────────────┼──────────────────┼──────────
   1 │ code         │ My Editor        │ ● focused
   2 │ firefox      │ Firefox — GitHub │ float
   3 │ kitty        │                  │ "
`;

exports[`formatWorkspaces > then matches snapshot 1`] = `
"3 workspace(s)

idx │ name     │ output │ status
────┼──────────┼────────┼──────────
  1 │ dev      │ DP-1   │ ● focused
  2 │ web      │ DP-1   │ ● active
  1 │          │ HDMI-1 │ "
`;
