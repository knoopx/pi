{
  "extends": "../../shared/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@mariozechner/pi-tui": [
        "./node_modules/@mariozechner/pi-tui"
      ],
      "@mariozechner/pi-coding-agent": [
        "./node_modules/@mariozechner/pi-coding-agent"
      ],
      "@mariozechner/pi-ai": [
        "./node_modules/@mariozechner/pi-ai"
      ],
      "@mariozechner/pi-agent-core": [
