{
  "name": "guardrails",
  "version": "1.0.0",
  "description": "Guardrails extension for pi-coding-agent - provides command blocking and confirmation based on patterns",
  "scripts": {
    "lint": "bun ./node_modules/eslint/bin/eslint.js",
    "test": "bun vitest run *.test.ts",
    "tsc": "tsc --noEmit"
  },
  "keywords": [
    "guardrails",
    "security",
    "blocking",
    "confirmation",
    "pi-coding-agent",
    "extension"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
