{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": ["screenshots/**"],
  "workspaces": {
    "agent/extensions/*": {
      "entry": ["./index.ts"],
      "project": ["**/*.ts"]
    },
    "agent/shared": {
      "entry": ["./guards.ts"],
      "project": ["**/*.ts"]
    }
  },
  "ignoreDependencies": ["typescript-eslint", "bun-types", "eslint"],
  "rules": {
    "enumMembers": "off"
  }
}
